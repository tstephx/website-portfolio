{
  "name": "website-portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio website. Static HTML/CSS with Chart.js visualizations.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:all": "playwright test",
    "test:visual": "playwright test tests/visual.spec.js",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report tests/report",
    "changelog": "node scripts/generate-changelog.js",
    "pretest": "node scripts/generate-changelog.js",
    "lint": "eslint js/ scripts/ tests/",
    "lint:fix": "eslint js/ scripts/ tests/ --fix",
    "format": "prettier --write '**/*.{js,css,html,json,md}'",
    "format:check": "prettier --check '**/*.{js,css,html,json,md}'",
    "lint:css": "stylelint 'css/**/*.css'",
    "lint:css:fix": "stylelint 'css/**/*.css' --fix",
    "lint:html": "html-validate 'index.html' 'resume.html' 'projects/*.html' 'work/bpr-scoring-pinnacle/pinnacle-scoring.html' 'work/cfa-dsp-application/dsp-application.html' 'work/charge-back-processing/chargeback-parsing.html' 'work/contract-transfer/contract-transfer.html' 'work/pinnacle-program-selection/pinnacle-automation.html' 'work/pinnacle-station/pinnacle-distance.html'",
    "check:links": "linkinator . --recurse --skip 'https://' --verbosity error",
    "check": "npm run lint && npm run lint:css && npm run format:check && npm run lint:html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tstephx/website-portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tstephx/website-portfolio/issues"
  },
  "homepage": "https://github.com/tstephx/website-portfolio#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@double-great/stylelint-a11y": "^3.4.5",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "html-validate": "^10.11.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
