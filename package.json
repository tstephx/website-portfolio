{
  "name": "website-portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio website. Static HTML/CSS with Chart.js visualizations.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:all": "playwright test",
    "test:visual": "playwright test tests/visual.spec.js",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report tests/report",
    "changelog": "node scripts/generate-changelog.js",
    "pretest": "node scripts/generate-changelog.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tstephx/website-portfolio.git"
  },
